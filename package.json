{
  "name": "launchcheck",
  "version": "0.1.1",
  "description": "Automated pre-launch QA for web projects: a CLI of static checks for code quality, dependencies, deployment, and documentation.",
  "license": "MIT",
  "author": "Apetu Ezekiel",
  "keywords": [
    "cli",
    "pre-launch",
    "prelaunch",
    "qa",
    "ci",
    "static-analysis",
    "lint",
    "launch-checklist",
    "devops"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Apetuezekiel/launchcheck-.git"
  },
  "homepage": "https://github.com/Apetuezekiel/launchcheck-#readme",
  "bugs": {
    "url": "https://github.com/Apetuezekiel/launchcheck-/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "launchcheck": "bin/launchcheck.mjs"
  },
  "files": ["dist", "bin", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check:surface": "bash scripts/check-public-surface.sh",
    "check:secrets": "node scripts/check-no-committed-secrets.mjs",
    "verify": "bash scripts/verify-checker.sh",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "5.4.1",
    "commander": "13.0.0",
    "glob": "10.4.5",
    "ignore": "5.3.2",
    "ora": "8.1.1",
    "undici": "6.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "22.10.5",
    "tsup": "8.3.5",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "peerDependencies": {
    "puppeteer": "*",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "puppeteer": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
