{
  "name": "launchcheck",
  "version": "0.0.0",
  "description": "Pre-launch project verification tool.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "launchcheck": "./bin/launchcheck.mjs"
  },
  "files": ["dist", "bin", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "5.4.1",
    "commander": "13.0.0",
    "glob": "10.4.5",
    "ignore": "5.3.2",
    "ora": "8.1.1",
    "undici": "6.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "22.10.5",
    "tsup": "8.3.5",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "peerDependencies": {
    "puppeteer": "*",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "puppeteer": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
